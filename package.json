{
  "name": "tree-sitter-nbcl",
  "version": "0.1.0",
  "description": "Tree sitter for Node Based Configuration Language (NBCL)",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nbcl-lang/tree-sitter-nbcl.git"
  },
  "funding": "https://ko-fi.com/byson94",
  "license": "MIT",
  "author": {
    "name": "Byson94",
    "email": "byson94wastaken@gmail.com",
    "url": "https://byson94.is-a.dev"
  },
  "main": "bindings/node",
  "types": "bindings/node",
  "keywords": [
    "incremental",
    "parsing",
    "tree-sitter",
    "nbcl"
  ],
  "files": [
    "grammar.js",
    "tree-sitter.json",
    "binding.gyp",
    "prebuilds/**",
    "bindings/node/*",
    "queries/*",
    "src/**",
    "*.wasm"
